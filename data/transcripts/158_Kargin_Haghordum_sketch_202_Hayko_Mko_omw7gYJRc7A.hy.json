      "text": "ապեր ի նկատուն եմ Արմեն դե բարմեն էլի հա"
    },
    {
      "start": 20.199,
      "end": 27.439,
      "text": "Արմենչիկ"
    },
    {
      "start": 22.039,
      "end": 27.439,
      "text": "Բարմենչիկ Փոշնի 50 լից"
    },
    {
      "start": 29.359,
      "end": 35.76,
      "text": "Ինչ-որ բան ենք նշում։ Ապե´ր, գազա"
    },
    {
      "start": 32.32,
      "end": 38.76,
      "text": "պարտիվկա եմ առել, պտի թռչենք։ Ու ի՞նչ"
    },
    {
      "start": 35.76,
      "end": 42.92,
      "text": "շարժեր։ 2000։"
    },
    {
      "start": 38.76,
      "end": 46.12,
      "text": "2000 ի՞նչ։ Դու էլ արել էլ ինչ։ Հա, շատ"
    },
    {
      "start": 42.92,
      "end": 46.12,
      "text": "լավ ա։"
    },
    {
      "start": 49.28,
      "end": 54.039,
      "text": "Այ"
    },
    {
      "start": 50.28,
      "end": 58.1,
      "text": "սկսել մի հատ էլ սոված փորին կլինի այսքան"
    },
    {
      "start": 54.039,
      "end": 62.96,
      "text": "խմել։ Սոված փորին դաժե սովալի են խմում"
    },
    {
      "start": 58.1,
      "end": 66.119,
      "text": "[երաժշտություն]"
    },
    {
      "start": 62.96,
      "end": 66.119,
      "text": "Հիմա իսկականից"
    },
    {
      "start": 66.72,
      "end": 69.72,
      "text": "սկսեց"
    },
    {
      "start": 70.68,
      "end": 87.32,
      "text": "[երաժշտություն]"
    },
    {
      "start": 82.52,
      "end": 89.0,
      "text": "լեզ պարտք թռչենք լից ուստո Տոպ մի տուր,"
    },
    {
      "start": 87.32,
      "end": 92.72,
      "text": "դու։"
    },
    {
      "start": 89.0,
      "end": 96.72,
      "text": "Կներեք էլի, բայց շատ չեք խմու՞մ։ Ապեր,"
    },
    {
      "start": 92.72,
      "end": 100.2,
      "text": "շատ, մենակ փղերն են խմում, այն էլ"
    },
    {
      "start": 96.72,
      "end": 100.2,
      "text": "պարսկական։ Կռվից"
    },
    {
      "start": 101.84,
      "end": 109.119,
      "text": "առաջ։ Վարդանի հետ մի հատ"
    },
    {
      "start": 105.479,
      "end": 112.48,
      "text": "էլ արա, սա ինչ սկսել"
    },
    {
      "start": 109.119,
      "end": 121.399,
      "text": "սկսել համբա՞ր ես, որ սկսել"
    },
    {
      "start": 112.48,
      "end": 124.079,
      "text": "[երաժշտություն]"
    },
    {
      "start": 121.399,
      "end": 126.63,
      "text": "Անուշ սկսել է"
    },
    {
      "start": 124.079,
      "end": 136.64,
      "text": "դավայ մի"
    },
    {
      "start": 126.63,
      "end": 140.16,
      "text": "[երաժշտություն]"
    },
    {
      "start": 136.64,
      "end": 142.72,
      "text": "ուշացրա էլի գոնե այսքան խմելու հետ մի"
    },
    {
      "start": 140.16,
      "end": 146.4,
      "text": "փոքր բան ուտենք գոնե. փոքր բան թո"
    },
    {
      "start": 142.72,
      "end": 153.99,
      "text": "մրջուներ ուզեն մենք ուտելուց մեզ"
    },
    {
      "start": 146.4,
      "end": 153.99,
      "text": "[երաժշտություն]"
    },
    {
      "start": 156.64,
      "end": 159.64,
      "text": "կուտենք"
    },
    {
      "start": 160.12,
      "end": 163.68,
      "text": "ապեր ես"
    },
    {
      "start": 166.28,
      "end": 172.47,
      "text": "մոշկի բուլկի"
    },
    {
      "start": 169.76,
      "end": 194.919,
      "text": "հետը մի հատ բուլկի կեր"
    },
    {
      "start": 172.47,
      "end": 194.919,
      "text": "[երաժշտություն]"
    },
    {
      "start": 203.03,
      "end": 210.28,
      "text": "[երաժշտություն]"
    },
    {
      "start": 205.319,
      "end": 210.28,
      "text": "Հը, լավ էր, տեսա բուլկիտ ինչ արեց:"
