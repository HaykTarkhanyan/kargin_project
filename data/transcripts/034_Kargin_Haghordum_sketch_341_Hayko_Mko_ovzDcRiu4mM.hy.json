    {
      "start": 3.799,
      "end": 9.059,
      "text": "դրելով կապ չունես դրե՞լ ես հա դա էլ եմ"
    },
    {
      "start": 6.54,
      "end": 11.719,
      "text": "դրել։ այդ էլ եմ ցավդ տանեմ տեսնենք"
    },
    {
      "start": 9.059,
      "end": 15.559,
      "text": "ճանապարհից առաջ լավ հերիք է"
