    {
      "start": 11.719,
      "end": 15.559,
      "text": "մի քանի օրով ես գնում"
    },
    {
      "start": 16.4,
      "end": 23.19,
      "text": "հինգ մի հատ այս բաները տենց բաներ ես"
    },
    {
