      "end": 35.78,
      "text": "մինչև այսօր չեմ մոռացել"
    },
    {
      "start": 36.86,
      "end": 41.16,
      "text": "բաժանվեն ինձ"
    },
    {
      "start": 38.7,
      "end": 42.92,
      "text": "ոնց են լարված է"
    },
    {
      "start": 41.16,
      "end": 48.62,
      "text": "[ծափահարություն]"
    },
    {
      "start": 42.92,
      "end": 48.62,
      "text": "արցախի հիշում ես դու սեր իմ"
    },
    {
      "start": 48.92,
      "end": 53.899,
      "text": "սիրո թախծոտ մեղեդին"
    },
    {
      "start": 54.02,
      "end": 60.079,
      "text": "որ միշտ քեզ համար եմ երգել"
    },
    {
      "start": 60.199,
      "end": 65.719,
      "text": "այս երգով իմ սերը հայտնել"
    },
    {
      "start": 66.92,
      "end": 72.56,
      "text": "արցախի հիշում ես դու սեր ինձ"
    },
    {
      "start": 73.31,
      "end": 77.799,
      "text": "[երաժշտություն]"
