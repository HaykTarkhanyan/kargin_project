      "end": 25.279,
      "text": "ուզում եմ չի"
    },
    {
      "start": 23.19,
      "end": 28.86,
      "text": "[երաժշտություն]"
    },
    {
      "start": 25.279,
      "end": 30.619,
      "text": "ճանապարհը քո մեջ"
