    },
    {
      "start": 90.439,
      "end": 98.4,
      "text": "թռվռալով կգնաս ուղղակի կտա"
    },
    {
      "start": 93.979,
      "end": 101.04,
      "text": "մարդ ի՞նչ ախ նորմալ բալասանյան ես որ"
    },
    {
      "start": 98.4,
      "end": 103.88,
      "text": "տարվեցի դու ինչ ուզեցիր ես քո համար"
    },
    {
      "start": 101.04,
      "end": 119.31,
      "text": "արեցի։ հիմա էլ դու արա ինձ համար"
    },
    {
