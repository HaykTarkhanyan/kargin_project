  "full_text": "[երաժշտություն]\nու\nսիրոզեց զամբախի\nդու մի\nլխիհեր դու սև դիակ մայր\n[երաժշտություն]\nհամաղերի մեր\nհամամաղերը պարտի\nսուրբ խաչես\n[երաժշտություն]\nալվացի մղերը դու դավանա\n[երաժշտություն]\nլեսերի չի\nնոգորի չիտմար գալի\nտոկա\nչթոգորի չի մարի քո\n[երաժշտություն]\nԲարև ձեզ\nբարև ո<un է\nձեր հարևանն\nէ դու\n[երաժշտություն]\nեսիմ\nկարենեսձեր զուգարանով հարևան\nեմ Ես վան\nես Բրյուսել եմ թռնում ասի թռիչքից առաջ\nմտնեմ զուգարան մի քիչ\nթեթևանամ էլ թարսի պես զուգարանի թուղթը\nվերջացել է կարո<un> է ձեր կաբինկում\nզուգարանի թուղթ լինի\nչէ ապեր վաբշե թուղթ չկա\n[երաժշտություն]\nիմ ռեյսն է, իսկ կարո է ինչ-որ ժուռնալ\nկամ թերթ ունենաք:\nՉէ, չունեմ, ցավդ\n[երաժշտություն]\nտանեմ: Կներեք, իսկ կարո է սա հազար\nնոստներով մանրեիք:\n[երաժշտություն]\n[ծափահարություն]\n[երաժշտություն]\nուզիրոզեցա սամպա\n[երաժշտություն]\nխիսվերի դու մի\nլխիզվեր թուր\nսևի բա\nսամերին մերամղերը\n[երաժշտություն]",
  "events": [
    {
      "start": 1.12,
      "end": 7.679,
      "text": "[երաժշտություն]"
    },
    {
      "start": 6.879,
      "end": 11.719,
      "text": "ու"
    },
    {
      "start": 7.679,
      "end": 11.719,
      "text": "սիրոզեց զամբախի"
    },
    {
      "start": 12.92,
      "end": 18.77,
      "text": "դու մի"
    },
    {
      "start": 14.04,
      "end": 20.32,
      "text": "լխիհեր դու սև դիակ մայր"
    },
    {
      "start": 18.77,
      "end": 22.359,
      "text": "[երաժշտություն]"
    },
    {
      "start": 20.32,
      "end": 24.72,
      "text": "համաղերի մեր"
    },
    {
      "start": 22.359,
      "end": 26.51,
      "text": "համամաղերը պարտի"
    },
    {
      "start": 24.72,
      "end": 29.72,
      "text": "սուրբ խաչես"
    },
    {
      "start": 26.51,
      "end": 33.88,
      "text": "[երաժշտություն]"
    },
    {
      "start": 29.72,
      "end": 36.84,
      "text": "ալվացի մղերը դու դավանա"
    },
    {
      "start": 33.88,
      "end": 38.879,
      "text": "[երաժշտություն]"
    },
    {
      "start": 36.84,
      "end": 43.32,
      "text": "լեսերի չի"
    },
    {
      "start": 38.879,
      "end": 43.32,
      "text": "նոգորի չիտմար գալի"
    },
    {
      "start": 45.0,
      "end": 50.42,
      "text": "տոկա"
    },
    {
      "start": 47.12,
      "end": 53.7,
      "text": "չթոգորի չի մարի քո"
    },
    {
      "start": 50.42,
      "end": 53.7,
      "text": "[երաժշտություն]"
    },
    {
      "start": 56.559,
      "end": 63.359,
      "text": "Բարև ձեզ"
    },
    {
      "start": 59.719,
      "end": 65.4,
      "text": "բարև ո<un է"
    },
    {
      "start": 63.359,
      "end": 67.91,
      "text": "ձեր հարևանն"
    },
    {
      "start": 65.4,
      "end": 70.2,
      "text": "է դու"
    },
    {
      "start": 67.91,
      "end": 72.759,
      "text": "[երաժշտություն]"
    },
    {
      "start": 70.2,
      "end": 77.04,
      "text": "եսիմ"
    },
    {
      "start": 72.759,
      "end": 77.04,
      "text": "կարենեսձեր զուգարանով հարևան"
    },
    {
      "start": 77.08,
      "end": 83.0,
      "text": "եմ Ես վան"
    },
    {
      "start": 79.92,
      "end": 84.88,
      "text": "ես Բրյուսել եմ թռնում ասի թռիչքից առաջ"
    },
    {
      "start": 83.0,
      "end": 88.439,
      "text": "մտնեմ զուգարան մի քիչ"
    },
    {
      "start": 84.88,
      "end": 91.64,
      "text": "թեթևանամ էլ թարսի պես զուգարանի թուղթը"
    },
    {
      "start": 88.439,
      "end": 95.399,
      "text": "վերջացել է կարո<un> է ձեր կաբինկում"
    },
    {
      "start": 91.64,
      "end": 95.399,
      "text": "զուգարանի թուղթ լինի"
    },
    {
      "start": 99.32,
      "end": 106.59,
      "text": "չէ ապեր վաբշե թուղթ չկա"
    },
    {
      "start": 101.52,
      "end": 106.59,
      "text": "[երաժշտություն]"
    },
    {
      "start": 110.439,
      "end": 115.96,
      "text": "իմ ռեյսն է, իսկ կարո է ինչ-որ ժուռնալ"
    },
    {
      "start": 113.439,
      "end": 117.73,
      "text": "կամ թերթ ունենաք:"
    },
    {
      "start": 115.96,
      "end": 120.809,
      "text": "Չէ, չունեմ, ցավդ"
    },
    {
      "start": 117.73,
      "end": 120.809,
      "text": "[երաժշտություն]"
    },
    {
      "start": 122.84,
      "end": 129.009,
      "text": "տանեմ: Կներեք, իսկ կարո է սա հազար"
    },
    {
      "start": 126.119,
      "end": 129.47,
      "text": "նոստներով մանրեիք:"
    },
    {
      "start": 129.009,
      "end": 130.449,
      "text": "[երաժշտություն]"
    },
    {
      "start": 129.47,
      "end": 134.84,
      "text": "[ծափահարություն]"
    },
    {
      "start": 130.449,
      "end": 136.91,
      "text": "[երաժշտություն]"
    },
    {
      "start": 134.84,
      "end": 139.12,
      "text": "ուզիրոզեցա սամպա"
    },
    {
      "start": 136.91,
      "end": 141.16,
      "text": "[երաժշտություն]"
    },
    {
      "start": 139.12,
      "end": 143.239,
      "text": "խիսվերի դու մի"
    },
    {
      "start": 141.16,
      "end": 147.0,
      "text": "լխիզվեր թուր"
    },
    {
      "start": 143.239,
      "end": 147.0,
      "text": "սևի բա"
    },
    {
      "start": 147.48,
      "end": 151.889,
      "text": "սամերին մերամղերը"
    },
    {
      "start": 149.55,
      "end": 151.889,
      "text": "[երաժշտություն]"
    }
  ]
