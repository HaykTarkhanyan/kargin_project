  "full_text": "[երաժշտություն]\nՀլա մտեք, հլա\n[երաժշտություն]\nբարև ձեզիմ\nգողացել են\nինչով կարողեք ինձ օգնել\nձևակերպենք\nԱնուն ազգանունը ասենք\nԱվետիկ Իսահակյան\n[երաժշտություն]\nայս ինչ ծանոթ տարուն ազգանուն է որտե\nլսած կլինեմ\nիմ հայրը մի երեք տարի առաջ վայն աշխատել\nգույնի մեքենա իչ մեքենա էր\nթվականի մուկմիր\nԱյս ի<unչ ձայներ են այնտեղ մարդ են\nծեծում\nչէ այ մարդ ի<չ ծեծել տղաները թենիս են\nլավ դուք գնացեք մենք հենց գտնենք մեքենան\nձեզ կտեղեկացնենք հլը հաջողություն\n[ծափահարություն]\n[երաժշտություն]\n[ծափահարություն]\n[ծափահարություն]\nԱլա ասա ինչ կա\nԼսում եմ սիրելի\nշատ վատ եմ որովհետև առավոտյան մեր\nմեքենան գողացել են\nինչպես թե դու ես վերցրել\nախր չի կարելի չէ առանց զգուշացնելու իմ\nմեքենան վերցնել\nՊետրոսյան ջան լավ հավեսով պարտիա էր\nի՞նչ պարզվավ\nԻնչ պարզվավ աղջկան գողացել բռնի ուժով էլ\nտիրացել\nարա բան ես արել հլը նայի աչքերիս մեջ հլը\nհլը նայի աչքերիս մեջ տենց բան ես արել\nչէ\nչէ\nՊետրոսյան ջան մինչև գնանք հաց ուտենք\nաչքիս այս գնդակին դու մի երկու հատ\nհավեսով տոպկես\nդավայ դավայ\nես արդեն եկել եմ ոստիկանություն և դիմում\nեմ գրել:\n[ծափահարություն]\nչէ սիրելի ես չեմ բղավում պարզապես մի\nփոքր նյարդայնացել եմ\nես դիմումը անպայման հետ կվերցնեմ\nես քեզ\nպաղա\nՀա,\nկներեք, ես իմ դիմում ուզում եմ հետ\nվերցնեմ:\nԻնչի՞ համար:\nԳիտեք, թյուրիմացություն է տեղի ունեցել:\nՊարզվեց, որ իմ մեքենան ամենևին էլ չեն\nգողացել: Պարզապես կինս վերցրել է և\nգնացել է խանութներով: Հենց նոր\nզանգահարեց զգուշացրեց:\nԸնկեր արի դու մեր գործերի մեջ մի խառնվի,\nմենք քո մաշնի գողին արդեն գտել ենք:\nԿարմիր մաշն է բռնաբարը",
  "events": [
    {
      "start": 0.2,
      "end": 4.059,
      "text": "[երաժշտություն]"
    },
    {
      "start": 2.08,
      "end": 7.249,
      "text": "Հլա մտեք, հլա"
    },
    {
      "start": 4.059,
      "end": 7.249,
      "text": "[երաժշտություն]"
    },
    {
      "start": 8.92,
      "end": 12.2,
      "text": "բարև ձեզիմ"
    },
    {
      "start": 14.0,
      "end": 18.92,
      "text": "գողացել են"
    },
    {
      "start": 16.359,
      "end": 21.119,
      "text": "ինչով կարողեք ինձ օգնել"
    },
    {
      "start": 18.92,
      "end": 22.6,
      "text": "ձևակերպենք"
    },
    {
      "start": 21.119,
      "end": 24.24,
      "text": "Անուն ազգանունը ասենք"
    },
    {
      "start": 22.6,
      "end": 25.72,
      "text": "Ավետիկ Իսահակյան"
    },
    {
      "start": 24.24,
      "end": 28.439,
      "text": "[երաժշտություն]"
    },
    {
      "start": 25.72,
      "end": 30.16,
      "text": "այս ինչ ծանոթ տարուն ազգանուն է որտե"
    },
    {
      "start": 28.439,
      "end": 35.92,
      "text": "լսած կլինեմ"
    },
    {
      "start": 30.16,
      "end": 35.92,
      "text": "իմ հայրը մի երեք տարի առաջ վայն աշխատել"
    },
    {
      "start": 37.6,
      "end": 44.399,
      "text": "գույնի մեքենա իչ մեքենա էր"
    },
    {
      "start": 40.6,
      "end": 44.399,
      "text": "թվականի մուկմիր"
    },
    {
      "start": 50.48,
      "end": 53.64,
      "text": "Այս ի<unչ ձայներ են այնտեղ մարդ են"
    },
    {
      "start": 52.92,
      "end": 58.84,
      "text": "ծեծում"
    },
    {
      "start": 53.64,
      "end": 61.76,
      "text": "չէ այ մարդ ի<չ ծեծել տղաները թենիս են"
    },
    {
      "start": 58.84,
      "end": 65.92,
      "text": "լավ դուք գնացեք մենք հենց գտնենք մեքենան"
    },
    {
      "start": 61.76,
      "end": 65.92,
      "text": "ձեզ կտեղեկացնենք հլը հաջողություն"
    },
    {
      "start": 67.35,
      "end": 70.38,
      "text": "[ծափահարություն]"
    },
    {
      "start": 69.31,
      "end": 73.52,
      "text": "[երաժշտություն]"
    },
    {
      "start": 70.38,
      "end": 73.52,
      "text": "[ծափահարություն]"
    },
    {
      "start": 75.97,
      "end": 80.2,
      "text": "[ծափահարություն]"
    },
    {
      "start": 77.159,
      "end": 80.2,
      "text": "Ալա ասա ինչ կա"
    },
    {
      "start": 83.04,
      "end": 87.799,
      "text": "Լսում եմ սիրելի"
    },
    {
      "start": 84.96,
      "end": 91.24,
      "text": "շատ վատ եմ որովհետև առավոտյան մեր"
    },
    {
      "start": 87.799,
      "end": 93.479,
      "text": "մեքենան գողացել են"
    },
    {
      "start": 91.24,
      "end": 95.04,
      "text": "ինչպես թե դու ես վերցրել"
    },
    {
      "start": 93.479,
      "end": 96.159,
      "text": "ախր չի կարելի չէ առանց զգուշացնելու իմ"
    },
    {
      "start": 95.04,
      "end": 99.04,
      "text": "մեքենան վերցնել"
    },
    {
      "start": 96.159,
      "end": 100.32,
      "text": "Պետրոսյան ջան լավ հավեսով պարտիա էր"
    },
    {
      "start": 99.04,
      "end": 103.799,
      "text": "ի՞նչ պարզվավ"
    },
    {
      "start": 100.32,
      "end": 105.159,
      "text": "Ինչ պարզվավ աղջկան գողացել բռնի ուժով էլ"
    },
    {
      "start": 103.799,
      "end": 108.84,
      "text": "տիրացել"
    },
    {
      "start": 105.159,
      "end": 111.36,
      "text": "արա բան ես արել հլը նայի աչքերիս մեջ հլը"
    },
    {
      "start": 108.84,
      "end": 112.88,
      "text": "հլը նայի աչքերիս մեջ տենց բան ես արել"
    },
    {
      "start": 111.36,
      "end": 114.56,
      "text": "չէ"
    },
    {
      "start": 112.88,
      "end": 117.159,
      "text": "չէ"
    },
    {
      "start": 114.56,
      "end": 119.039,
      "text": "Պետրոսյան ջան մինչև գնանք հաց ուտենք"
    },
    {
      "start": 117.159,
      "end": 120.32,
      "text": "աչքիս այս գնդակին դու մի երկու հատ"
    },
    {
      "start": 119.039,
      "end": 122.119,
      "text": "հավեսով տոպկես"
    },
    {
      "start": 120.32,
      "end": 123.799,
      "text": "դավայ դավայ"
    },
    {
      "start": 122.119,
      "end": 126.96,
      "text": "ես արդեն եկել եմ ոստիկանություն և դիմում"
    },
    {
      "start": 123.799,
      "end": 126.96,
      "text": "եմ գրել:"
    },
    {
      "start": 127.42,
      "end": 135.56,
      "text": "[ծափահարություն]"
    },
    {
      "start": 132.12,
      "end": 138.28,
      "text": "չէ սիրելի ես չեմ բղավում պարզապես մի"
    },
    {
      "start": 135.56,
      "end": 141.8,
      "text": "փոքր նյարդայնացել եմ"
    },
    {
      "start": 138.28,
      "end": 145.2,
      "text": "ես դիմումը անպայման հետ կվերցնեմ"
    },
    {
      "start": 141.8,
      "end": 145.2,
      "text": "ես քեզ"
    },
    {
      "start": 149.92,
      "end": 154.519,
      "text": "պաղա"
    },
    {
      "start": 151.519,
      "end": 154.519,
      "text": "Հա,"
    },
    {
      "start": 158.64,
      "end": 161.44,
      "text": "կներեք, ես իմ դիմում ուզում եմ հետ"
    },
    {
      "start": 160.56,
      "end": 162.8,
      "text": "վերցնեմ:"
    },
    {
      "start": 161.44,
      "end": 165.2,
      "text": "Ինչի՞ համար:"
    },
    {
      "start": 162.8,
      "end": 167.2,
      "text": "Գիտեք, թյուրիմացություն է տեղի ունեցել:"
    },
    {
      "start": 165.2,
      "end": 169.599,
      "text": "Պարզվեց, որ իմ մեքենան ամենևին էլ չեն"
    },
    {
      "start": 167.2,
      "end": 171.319,
      "text": "գողացել: Պարզապես կինս վերցրել է և"
    },
    {
      "start": 169.599,
      "end": 173.44,
      "text": "գնացել է խանութներով: Հենց նոր"
    },
    {
      "start": 171.319,
      "end": 176.92,
      "text": "զանգահարեց զգուշացրեց:"
    },
    {
      "start": 173.44,
      "end": 180.92,
      "text": "Ընկեր արի դու մեր գործերի մեջ մի խառնվի,"
    },
    {
      "start": 176.92,
      "end": 180.92,
      "text": "մենք քո մաշնի գողին արդեն գտել ենք:"
    },
    {
      "start": 182.239,
      "end": 187.0,
      "text": "Կարմիր մաշն է բռնաբարը"
    }
  ]
}